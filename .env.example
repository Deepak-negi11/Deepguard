# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_APP_NAME=DeepGuard

# Backend
DEEPGUARD_DATABASE_URL=sqlite:///./deepguard.db
DEEPGUARD_SECRET_KEY=change-me-in-production
DEEPGUARD_ACCESS_TOKEN_EXPIRE_MINUTES=120
DEEPGUARD_CORS_ORIGINS=http://localhost:3000
DEEPGUARD_UPLOAD_ROOT=./uploads
DEEPGUARD_MAX_UPLOAD_MB=250
DEEPGUARD_ENABLE_DEMO_ANALYZERS=true
DEEPGUARD_ENABLE_CELERY_WORKERS=false
DEEPGUARD_ENABLE_API_USAGE_LOGGING=true
DEEPGUARD_RATE_LIMIT_REQUESTS_PER_HOUR=100
DEEPGUARD_DELETE_UPLOADS_AFTER_PROCESSING=true

# Async services
DEEPGUARD_REDIS_URL=redis://redis:6379/0
DEEPGUARD_CELERY_BROKER_URL=redis://redis:6379/0
DEEPGUARD_CELERY_RESULT_BACKEND=redis://redis:6379/1
